#!/bin/sh

# Refresh scholar data if content/scholar.yaml wasn't updated today
SCHOLAR_YAML="content/scholar.yaml"

if [ ! -f "$SCHOLAR_YAML" ]; then
  exit 0
fi

TODAY=$(date +%Y-%m-%d)
FILE_DATE=$(date -r "$SCHOLAR_YAML" +%Y-%m-%d 2>/dev/null || stat -c %Y "$SCHOLAR_YAML" 2>/dev/null | xargs -I{} date -d @{} +%Y-%m-%d 2>/dev/null)

if [ "$FILE_DATE" = "$TODAY" ]; then
  echo "[pre-push] scholar.yaml already updated today, skipping refresh"
  exit 0
fi

echo "[pre-push] Refreshing scholar data..."
npx tsx scripts/update-scholar.ts

if [ $? -eq 0 ] && git diff --quiet "$SCHOLAR_YAML" 2>/dev/null; [ $? -ne 0 ]; then
  git add "$SCHOLAR_YAML"
  git commit --amend --no-edit
  echo "[pre-push] Updated scholar.yaml and amended commit"
fi

exit 0
